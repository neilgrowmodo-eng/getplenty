{%- doc -%}

    version: 1.0.0
    name: Espresso Reframe
    description: Snippet installed by Espresso Reframe. Called from start of <head> in layout.liquid. Will be removed on deactivation.
    note: this snippet only deals with OG tags relevant for images. DO NOT remove your theme's standard metadata setup

{%- enddoc -%}

{%- liquid

    assign page_image_width = 1200
    assign page_image_height = 628

    assign seconds = "now" | date: "%s"
    assign v = "?v=" | append: seconds

    if page_image
        assign page_image_url = page_image | image_url
        assign default_image = "&default=https:" | append: page_image_url
    endif

    assign espresso_url = "https://cdn.espresso.pics/reframe/" | append: shop.permanent_domain | append: "/" | append: request.page_type | append: "/"

    if request.page_type == 'product'

        assign og_image = espresso_url | append: product.id | append: v | append: default_image
        assign og_image_alt = product.title

    elsif request.page_type == 'collection'

        assign og_image = espresso_url | append: collection.id | append: v | append: default_image
        assign og_image_alt = collection.title

    elsif request.page_type == 'article'

        assign og_image = espresso_url | append: article.id | append: v | append: default_image
        assign og_image_alt = article.title

    elsif request.page_type == 'blog'

        assign og_image = espresso_url | append: blog.id | append: v | append: default_image
        assign og_image_alt = blog.title

    elsif request.page_type == 'page'

        assign og_image = espresso_url | append: page.id | append: v | append: default_image
        assign og_image_alt = page.title

    endif

%}

{%- if settings.espresso_reframe_enabled and og_image -%}

    <meta property="og:image" content="{{ og_image }}" />
    <meta property="og:image:secure_url" content="{{ og_image }}" />
    <meta property="og:image:alt" content="{{ og_image_alt }}" />

    <meta property="twitter:card" content="summary_large_image"/>
    <meta property="twitter:image" content="{{ og_image }}" />

    <meta property="og:image:width" content="{{ page_image_width }}" />
    <meta property="og:image:height" content="{{ page_image_height }}" />
    <meta property="og:image:type" content="image/png" />

{%- endif -%}
