{%- assign products = product.metafields.p80.shop_the_look.value -%}
{%- if products.count > 0 and request.design_mode == false -%}
  {{ 'component-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}

  <link
    rel='stylesheet'
    href='{{ 'quick-add.css' | asset_url }}'
    media='print'
    onload="this.media='all'"
  >
  <script src='{{ 'quick-add.js' | asset_url }}' defer='defer'></script>

  <link
    rel='stylesheet'
    href='{{ 'p80-shop-the-look.css' | asset_url }}'
    media='print'
    onload="this.media='all'"
  >

  <noscript>{{ 'p80-shop-the-look.css' | asset_url | stylesheet_tag }}</noscript>

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: 2.4rem;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class='shop-the-look color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding'>
    <div class='page-width'>
      <h2 class='shop-the-look__title'>{{ section.settings.title }}</h2>
      <div class='shop-the-look__grid grid grid--1-col grid--2-col-tablet grid--5-col-desktop'>
        {%- for product in products -%}
          <div class='grid__item shop-the-look__item'>
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'portrait',
              show_secondary_image: true,
              show_vendor: true,
              show_rating: false,
              show_quick_add: true,
              section_id: section.id
            %}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "P80 Shop the look",
  "class": "section section--shop-the-look",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.p80-shop-the-look.settings.title.label",
      "default": "Shop The Look"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
