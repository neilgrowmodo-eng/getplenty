<link
  rel='stylesheet'
  href='{{ 'section-main-brands.css' | asset_url }}'
  media='print'
  onload="this.media='all'"
>

<noscript>{{ 'section-main-brands.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.92 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class='page-width color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding'>
  <h1 class='main-page-title page-title hxxl'>
    {{ page.title | escape }}
  </h1>
  {%- liquid
    assign links = ''
    assign blocks = ''
  -%}
  {% for link in linklists.brands.links %}
    {% if link.links != blank %}
      {% capture links %}
                {{ links }}
                <a href="#{{ link.title }}" class="link-text-bold">{{ link.title }}</a>
            {% endcapture %}
      {% capture blocks %}
              {{ blocks }}
              <div class="brands__item" id="{{ link.title }}">
                  <h5 class="hxxl brands__title">{{ link.title }}</h5>
                  <ul>
                      {% for sublink in link.links %}
                          {% if sublink.url == '#' %}
                              {% assign link_url = '/collections/vendors?q=' | append: sublink.title | replace: '&', '%26' | replace: '+', '%2B' %}
                          {% else %}
                              {% assign link_url = sublink.url %}
                          {% endif %}
                          <li><a href="{{ link_url }}" title="{{ sublink.title | escape }}">{{ sublink.title }}</a></li>
                      {% endfor %}
                  </ul>
              </div>
            {% endcapture %}
    {% endif %}
  {% endfor %}
  {% if links != blank %}
    <div class='brands__initials'>
      {{ links }}
    </div>
    <div class='brands__list'>
      {{ blocks }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
