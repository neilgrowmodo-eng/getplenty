{{ 'p80-accordion.css' | asset_url | stylesheet_tag }}
{{ 'section-faqs.css' | asset_url | stylesheet_tag }}
{{ 'main-careers-color-schemes.css.liquid' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding .faq-list {
      width: calc(100% + 3rem);
      margin-left: -1.5rem;
      margin-right: -1.5rem;
    }
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% if section.blocks.size > 0 %}
  <div class='faqs page-width section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient'>
    {%- if section.settings.heading != blank -%}
      <h2 class='title title-wrapper--no-top-margin {{ section.settings.heading_size }}'>
        {{ section.settings.heading | escape }}
      </h2>
    {%- else -%}
      <h2 class='title title-wrapper--no-top-margin {{ section.settings.heading_size }}'>
        {{ page.title | escape }}
      </h2>
    {%- endif -%}
    <div class='faq-content-wrap'>
      <div class='faq-list accordion delivery-returns'>
        {%- for block in section.blocks -%}
          {% if block.settings.title != blank and block.settings.text != blank %}
            <accordion-component class='accordion__item'>
              <button
                class='accordion__button'
                aria-expanded='false'
                aria-controls='accordion-content-{{ section.id }}-{{ forloop.index0 }}'
                id='accordion-control-{{ section.id }}-{{ forloop.index0 }}'
                data-toggle
              >
                <span class='accordion__title'>{{ block.settings.title }}</span>
                <span class='accordion__icon'></span>
              </button>
              <div
                class='accordion__content'
                aria-hidden='true'
                id='accordion-content-{{ section.id }}-{{ forloop.index0 }}'
                data-content
              >
                {{ block.settings.text }}
              </div>
            </accordion-component>
          {% endif %}
        {%- endfor -%}
      </div>
      {% if page.content != blank %}
        <div class='widget-content'>
          {{ page.content }}
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Careers",
  "tag": "section",
  "class": "section--careers",
  "blocks": [
    {
      "type": "entry",
      "name": "Entry",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.main-careers.blocks.entry.settings.title.label",
          "default": "Warehouse (Vancouver)",
          "placeholder": "Add the location"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.main-careers.blocks.entry.settings.text.label",
          "default": "<p>Lorem ipsum dolor sit amet, consectetur adipisicing elit. Quae, nam?</p>"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Careers",
      "label": "t:sections.main-careers.settings.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "hxxl",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name"
    }
  ]
}
{% endschema %}
