{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .banner__text.body.hide--on-desktop,
  .banner__buttons.hide--on-desktop.banner__buttons--multiple.banner__buttons--custom {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .hide--on-desktop {
      display: block;
    }

    .banner__text.body.hide--on-desktop {
      display: block;
    }
    
    .hide--on-mobile {
      display: none !important;
    }
  }

  #Banner-{{ section.id }}::after {
    opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
  }
  {%- unless section.settings.heading_font_override == 'global' -%}
    #Banner-{{ section.id }} {
      {%- if section.settings.heading_font_override == 'canopee' -%}
        --font-heading-family: 'Canopee', sans-serif;
      {%- elsif section.settings.heading_font_override == 'caslon' -%}
        --font-heading-family: 'Caslon Ionic', serif;
      {%- endif -%}
    }
  {%- endunless -%}

  {%- unless section.settings.body_font_override == 'global' -%}
    #Banner-{{ section.id }} {
      {%- if section.settings.body_font_override == 'canopee' -%}
        --font-body-family: 'Canopee', sans-serif;
      {%- elsif section.settings.body_font_override == 'caslon' -%}
        --font-body-family: 'Caslon Ionic', serif;
      {%- endif -%}
    }
  {%- endunless -%}

  #Banner-{{ section.id }} {
    --font-heading-scale: {{ section.settings.heading_scale_override | divided_by: 100.0 }};
    --font-body-scale: {{ section.settings.body_scale_override | divided_by: 100.0 }};
  }

  /* Ensure banner text uses the local --font-body-scale instead of fixed rems */
  #Banner-{{ section.id }} .banner__text {
    font-size: calc(var(--font-body-base) * var(--font-body-scale));
  }

  @media screen and (min-width: 768px) {
    #Banner-{{ section.id }} .banner__text span {
      font-size: calc(var(--font-body-base) * var(--font-body-scale));
    }
  }


{%- endstyle -%}

<div id="Banner-{{ section.id }}" class="banner--image banner color-{{ section.settings.color_scheme }} gradient banner--content-align-{{ section.settings.desktop_content_position | replace: 'middle-' }} banner--content-align-mobile-{{ section.settings.mobile_content_alignment }} banner--large{% if section.settings.stack_images_on_mobile and section.settings.image != blank and section.settings.image_2 != blank %} banner--stacked{% endif %}{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}">
  {%- if section.settings.image != blank -%}
    <div class="banner__media media{% if section.settings.image == blank and section.settings.image_2 == blank %} placeholder{% endif %}{% if section.settings.image_2 != blank %} banner__media-half{% endif %} first-image">
      {%-liquid
        assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
        if section.settings.image_2 != blank
          assign image_class = "banner__media-image-half"
        endif
        if section.settings.image_2 != blank and section.settings.stack_images_on_mobile
          assign sizes = "(min-width: 750px) 50vw, 100vw"
        elsif section.settings.image_2 != blank
          assign sizes = "50vw"
        else
          assign sizes = "100vw"
        endif
      -%}
      {{ section.settings.image | image_url: width: 1500 | image_tag:
        loading: 'lazy',
        width: section.settings.image.width,
        height: image_height,
        class: image_class,
        sizes: sizes,
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
        alt: section.settings.image.alt | escape
      }}
    </div>
  {%- elsif section.settings.image_2 == blank -%}
    <div class="banner__media media{% if section.settings.image == blank and section.settings.image_2 == blank %} placeholder{% endif %}{% if section.settings.image_2 != blank %} banner__media-half{% endif %} second-image">
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    </div>
  {%- endif -%}
  {%- if section.settings.image_2 != blank -%}
    <div class="banner__media media{% if section.settings.image != blank %} banner__media-half{% endif %} second-image">
      {%-liquid
        assign image_height_2 = section.settings.image_2.width | divided_by: section.settings.image_2.aspect_ratio
        if section.settings.image != blank
          assign image_class_2 = "banner__media-image-half"
        endif
        if section.settings.image != blank and section.settings.stack_images_on_mobile
          assign sizes = "(min-width: 750px) 50vw, 100vw"
        elsif section.settings.image != blank
          assign sizes = "50vw"
        else
          assign sizes = "100vw"
        endif
      -%}
      {{ section.settings.image_2 | image_url: width: 1500 | image_tag:
        loading: 'lazy',
        width: section.settings.image_2.width,
        height: image_height_2,
        class: image_class_2,
        sizes: sizes,
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
        alt: section.settings.image_2.alt | escape
      }}
    </div>
  {%- endif -%}
  <div class="banner__content banner__content--{{ section.settings.desktop_content_position }} page-width">
    {%- assign scheme = section.settings.color_scheme -%}
    <div class="banner__box content-container content-container--full-width-mobile color-{{ scheme }}" style="--color-foreground: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }}; --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }}; --color-button-text: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }}; color: rgb(var(--color-foreground)); background-color: transparent;">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            {% style %}

              {% if block.settings.custom_heading_positioning %}
                #Banner-{{ section.id }} .banner__heading.custom-heading-positioning {
                  text-align: {{ block.settings.heading_alignment }};
                  width: 100%;
                  display: flex;
                  justify-content: {{ block.settings.heading_alignment }};
                  align-items: {{ block.settings.heading_align_item_position }};
                }

                @media screen and (max-width: 749px) {
                  #Banner-{{ section.id }} .banner__heading.custom-heading-positioning {
                    text-align: {{ block.settings.heading_alignment_mobile }};
                    width: 100%;
                    display: flex;
                    justify-content: {{ block.settings.heading_alignment_mobile }};
                    align-items: {{ block.settings.heading_align_item_position_mobile }};
                  }
                }
              {% endif %}
            {% endstyle %}
            <h2 class="banner__heading {{ block.settings.heading_size }} {% if block.settings.custom_heading_positioning %}custom-heading-positioning{% endif %}" {{ block.shopify_attributes }}>
              <span>{{ block.settings.heading | newline_to_br }}</span>
            </h2>
          {%- when 'text' -%}
            <div class="banner__text body hide--on-mobile" {{ block.shopify_attributes }}>
              <span>{{ block.settings.text | newline_to_br }}</span>
            </div>
            {% if block.settings.custom_text_positioning %}
              <style>
                #Banner-{{ section.id }} .banner__text[data-block-id="{{ block.id }}"] {
                  text-align: {{ block.settings.text_alignment }};
                  width: 100%;
                  max-width: 100%;
                }
                
                @media screen and (max-width: 749px) {
                  #Banner-{{ section.id }} .banner__text {
                    text-align: {{ block.settings.text_alignment_mobile }};
                    width: 100%;
                  }
                }
              </style>
            {% endif %}
          {%- when 'buttons' -%}
            <div class="banner__buttons hide--on-mobile{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} banner__buttons--multiple{% endif %} {%  if block.settings.custom_button_positioning %} banner__buttons--custom{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a{% if block.settings.button_link_1 != blank %} href="{{ block.settings.button_link_1 }}"{% endif %} class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %} button_number_1">{{ block.settings.button_label_1 | escape }}</a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a{% if block.settings.button_link_2 != blank %} href="{{ block.settings.button_link_2 }}"{% endif %} class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %} button_number_2">{{ block.settings.button_label_2 | escape }}</a>
              {%- endif -%}

            </div>
            <style>
              {% if block.settings.enable_custom_button_styles == true %}
                
                #Banner-{{ section.id }} .banner__box .button_number_1 {
                  background-color: {{ block.settings.button_color }};
                  color: {{ block.settings.button_text_color }};
                  border: {{ block.settings.button_outline_color }} {{ block.settings.button_border_width }}px solid;
                }
                #Banner-{{ section.id }} .banner__box .button_number_2 {
                  background-color: {{ block.settings.button_color_2 }};
                  color: {{ block.settings.button_text_color_2 }};
                  border: {{ block.settings.button_outline_color_2 }} {{ block.settings.button_border_width_2 }}px solid;
                }

                .button::after {
                  box-shadow: none;
                }

                .button:not([disabled]):hover:after {
                  box-shadow: none;
                }
              {% endif %}
              {% if block.settings.custom_button_positioning %}
                @media screen and (min-width: 750px) {
                  #Banner-{{ section.id }} .banner__buttons--custom {
                    display: flex;
                    max-width: none;
                    width: 100%;
                    justify-content: {{ block.settings.button_alignment }};
                  }

                  #Banner-{{ section.id }} .banner__buttons .button {
                    max-width: 212px;
                  }
                }
              {% endif %}
            </style>

        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>
<div class="blocks__container color-{{ section.settings.color_scheme }}">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'text' -%}
        <div class="banner__text body hide--on-desktop" {{ block.shopify_attributes }}>
          <span>{{ block.settings.text | newline_to_br }}</span>
        </div>
        {% if block.settings.custom_text_positioning %}
          <style>
            .blocks__container .banner__text[data-block-id="{{ block.id }}"] {
              text-align: {{ block.settings.text_alignment }};
              width: 100%;
              max-width: 100%;
            }
            
            @media screen and (max-width: 749px) {
              .blocks__container {
                padding: 0 15px 45px 15px; 
              }

              .blocks__container .banner__text {
                text-align: {{ block.settings.text_alignment_mobile }};
                width: 100%;
              }

              .banner__text.body.hide--on-desktop {
                padding-bottom: 15px;
              }
            }
          </style>
        {% endif %}
      {%- when 'buttons' -%}
        <div {% if block.settings.custom_button_positioning %} id="mobile_buttons" {% endif %} class="banner__buttons hide--on-desktop{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} banner__buttons--multiple{% endif %} {%  if block.settings.custom_button_positioning %} banner__buttons--custom{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.button_label_1 != blank -%}
            <a{% if block.settings.button_link_1 != blank %} href="{{ block.settings.button_link_1 }}"{% endif %} class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %} button_number_1">{{ block.settings.button_label_1 | escape }}</a>
          {%- endif -%}
          {%- if block.settings.button_label_2 != blank -%}
            <a{% if block.settings.button_link_2 != blank %} href="{{ block.settings.button_link_2 }}"{% endif %} class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %} button_number_2">{{ block.settings.button_label_2 | escape }}</a>
          {%- endif -%}

        </div>
        <style>
          {% if block.settings.enable_custom_button_styles == true %}
            
            .blocks__container .button_number_1 {
              background-color: {{ block.settings.button_color }};
              color: {{ block.settings.button_text_color }};
              border: {{ block.settings.button_outline_color }} {{ block.settings.button_border_width }}px solid;
            }
            .blocks__container .button_number_2 {
              background-color: {{ block.settings.button_color_2 }};
              color: {{ block.settings.button_text_color_2 }};
              border: {{ block.settings.button_outline_color_2 }} {{ block.settings.button_border_width_2 }}px solid;
            }

            .button::after {
              box-shadow: none;
            }

            .button:not([disabled]):hover:after {
              box-shadow: none;
            }
          {% endif %}
          {% if block.settings.custom_button_positioning %}
            .blocks__container .banner__buttons--custom {
              display: none;
            }
            
            @media screen and (max-width: 750px) {
              .blocks__container #mobile_buttons.banner__buttons--custom {
                display: flex;
                max-width: none;
                width: 100%;
                justify-content: {{ block.settings.button_alignment_mobile }};
              }

              .blocks__container #mobile_buttons.banner__buttons .button {
                width: 100%;
                max-width: 150px;
                padding: 0;
                min-width: auto;
              }
            }
          {% endif %}
        </style>

    {%- endcase -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "t:sections.image-banner.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image-banner.settings.image.label",
      "info": "t:sections.image-banner.settings.image.info"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "t:sections.image-banner.settings.image_2.label",
      "info": "t:sections.image-banner.settings.image_2.info"
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "t:sections.image-banner.settings.image_overlay_opacity.label",
      "default": 0
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        {
          "value": "middle-left",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__4.label"
        },
        {
          "value": "middle-center",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__5.label"
        },
        {
          "value": "middle-right",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__6.label"
        }
      ],
      "default": "middle-center",
      "label": "t:sections.image-banner.settings.desktop_content_position.label"
    },
    {
      "type": "header",
      "content": "t:sections.image-banner.settings.header.content"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image-banner.settings.mobile_content_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.image-banner.settings.mobile_content_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.image-banner.settings.mobile_content_alignment.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.image-banner.settings.mobile_content_alignment.label"
    },
    {
      "type": "checkbox",
      "id": "stack_images_on_mobile",
      "default": true,
      "label": "t:sections.image-banner.settings.stack_images_on_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "show_text_below",
      "default": true,
      "label": "t:sections.image-banner.settings.show_text_below.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Typography"
    },
    {
      "type": "select",
      "id": "heading_font_override",
      "label": "Heading font",
      "options": [
        { "value": "global", "label": "Use global setting" },
        { "value": "canopee", "label": "Canopee (custom)" },
        { "value": "caslon", "label": "Caslon Ionic (custom)" }
      ],
      "default": "global"
    },
    {
      "type": "range",
      "id": "heading_scale_override",
      "min": 75,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "t:settings_schema.typography.settings.heading_scale.label",
      "default": 100
    },
    {
      "type": "select",
      "id": "body_font_override",
      "label": "Body font",
      "options": [
        { "value": "global", "label": "Use global setting" },
        { "value": "canopee", "label": "Canopee (custom)" },
        { "value": "caslon", "label": "Caslon Ionic (custom)" }
      ],
      "default": "global"
    },
    {
      "type": "range",
      "id": "body_scale_override",
      "min": 75,
      "max": 130,
      "step": 5,
      "unit": "%",
      "label": "t:settings_schema.typography.settings.body_scale.label",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.image-banner.blocks.heading.name",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "default": "Image banner",
          "label": "t:sections.image-banner.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h0",
              "label": "t:sections.all.heading_size.options__3.label"
            }
          ],
          "default": "h1",
          "label": "t:sections.all.heading_size.label"
        },
        {
          "type": "header",
          "content": "Text Positioning"
        },
        {
          "type": "checkbox",
          "id": "custom_heading_positioning",
          "default": false,
          "label": "Enable custom heading positioning"
        },
        {
          "type": "select",
          "id": "heading_alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center",
          "label": "Heading alignment",
        },
        {
          "type": "select",
          "id": "heading_align_item_position",
          "options": [
            { "value": "flex-start", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "Bottom" }
          ],
          "default": "flex-start",
          "label": "Heading vertical alignment"
        },
        {
          "type": "select",
          "id": "heading_alignment_mobile",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center",
          "label": "Heading alignment (mobile)",
        },
        {
          "type": "select",
          "id": "heading_align_item_position_mobile",
          "options": [
            { "value": "flex-start", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "Bottom" }
          ],
          "default": "flex-start",
          "label": "Heading vertical alignment (mobile)"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.image-banner.blocks.text.name",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "default": "Give customers details about the banner image(s) or content on the template.",
          "label": "t:sections.image-banner.blocks.text.settings.text.label"
        },
        {
          "type": "header",
          "content": "Text Positioning"
        },
        {
          "type": "checkbox",
          "id": "custom_text_positioning",
          "default": false,
          "label": "Enable custom text positioning"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center",
          "label": "Text alignment (desktop)"
        },
        {
          "type": "select",
          "id": "text_alignment_mobile",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center",
          "label": "Text alignment (mobile)"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "t:sections.image-banner.blocks.buttons.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Button label",
          "label": "t:sections.image-banner.blocks.buttons.settings.button_label_1.label",
          "info": "t:sections.image-banner.blocks.buttons.settings.button_label_1.info"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "t:sections.image-banner.blocks.buttons.settings.button_link_1.label"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary_1",
          "default": false,
          "label": "t:sections.image-banner.blocks.buttons.settings.button_style_secondary_1.label"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "default": "Button label",
          "label": "t:sections.image-banner.blocks.buttons.settings.button_label_2.label",
          "info": "t:sections.image-banner.blocks.buttons.settings.button_label_2.info"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "t:sections.image-banner.blocks.buttons.settings.button_link_2.label"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary_2",
          "default": false,
          "label": "t:sections.image-banner.blocks.buttons.settings.button_style_secondary_2.label"
        },
        {
          "type": "header",
          "content": "Custom Button Styles"
        },
        {
          "type": "checkbox",
          "id": "enable_custom_button_styles",
          "default": false,
          "label": "Enable custom button styles"
        },
        {
          "type": "header",
          "content": "Button 1 styles"
        },
        {
          "type": "color",
          "id": "button_color",
          "label": "Button background color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button_outline_color",
          "label": "Button outline color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "button_border_width",
          "min": 0,
          "max": 10,
          "step": 1,
          "unit": "px",
          "label": "Button border width",
          "default": 0
        },
        {
          "type": "header",
          "content": "Button 2 styles"
        },
        {
          "type": "color",
          "id": "button_color_2",
          "label": "Button background color",
          "default": "#000000"
