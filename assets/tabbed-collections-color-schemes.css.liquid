/* stylelint-disable */
/* Tabbed-collections-specific color scheme mappings generated from settings.color_schemes (color_scheme_group) */
{% assign schemes = 'scheme-1,scheme-2,scheme-3,scheme-4,scheme-5' | split: ',' %}
{% for scheme_id in schemes %}
  {% assign scheme = settings.color_schemes[scheme_id] %}
  {% if scheme != blank %}
.collection-tabbed-wrapper.color-{{ scheme_id }} {
  --color-foreground: {{ scheme.settings.text | color_extract: 'red' }}, {{ scheme.settings.text | color_extract: 'green' }}, {{ scheme.settings.text | color_extract: 'blue' }};
  --color-background: {{ scheme.settings.background | color_extract: 'red' }}, {{ scheme.settings.background | color_extract: 'green' }}, {{ scheme.settings.background | color_extract: 'blue' }};
  {% if scheme.settings.background_gradient != blank %}
    --gradient-background: {{ scheme.settings.background_gradient }};
  {% else %}
    --gradient-background: rgba({{ scheme.settings.background | color_extract: 'red' }}, {{ scheme.settings.background | color_extract: 'green' }}, {{ scheme.settings.background | color_extract: 'blue' }}, 1);
  {% endif %}
  --color-button: {{ scheme.settings.button | color_extract: 'red' }}, {{ scheme.settings.button | color_extract: 'green' }}, {{ scheme.settings.button | color_extract: 'blue' }};
  --color-button-text: {{ scheme.settings.button_label | color_extract: 'red' }}, {{ scheme.settings.button_label | color_extract: 'green' }}, {{ scheme.settings.button_label | color_extract: 'blue' }};
  --color-link: {{ scheme.settings.secondary_button_label | color_extract: 'red' }}, {{ scheme.settings.secondary_button_label | color_extract: 'green' }}, {{ scheme.settings.secondary_button_label | color_extract: 'blue' }};

  background-color: rgb(var(--color-background)) !important;
  color: rgb(var(--color-foreground));
}

.collection-tabbed-wrapper.color-{{ scheme_id }}.gradient {
  background: var(--gradient-background) !important;
}

/* Tabbed collections wrapper styling */
.collection-tabbed-wrapper.color-{{ scheme_id }} {
  color: rgb(var(--color-foreground));
}

/* Collection tabs styling */
.collection-tabbed-wrapper.color-{{ scheme_id }} .collection-tabs {
  color: rgb(var(--color-foreground));
}

.collection-tabbed-wrapper.color-{{ scheme_id }} .collection-tabs .tab {
  color: rgb(var(--color-foreground));
  border-color: rgb(var(--color-foreground));
}

.collection-tabbed-wrapper.color-{{ scheme_id }} .collection-tabs .tab:hover,
.collection-tabbed-wrapper.color-{{ scheme_id }} .collection-tabs .tab[aria-selected="true"] {
  background-color: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  border-color: rgb(var(--color-button));
}

/* Collection cards styling */
.collection-tabbed-wrapper.color-{{ scheme_id }} .collection-tabbed__item {
  color: rgb(var(--color-foreground));
}

/* Link styling */
.collection-tabbed-wrapper.color-{{ scheme_id }} a:not(.button) {
  color: rgb(var(--color-link));
}

.collection-tabbed-wrapper.color-{{ scheme_id }} a:not(.button):hover {
  color: rgb(var(--color-button));
}
  {% endif %}
{% endfor %}
