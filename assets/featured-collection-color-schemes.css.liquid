/* stylelint-disable */
/* Featured-collection-specific color scheme mappings generated from settings.color_schemes (color_scheme_group) */
{% assign schemes = 'scheme-1,scheme-2,scheme-3,scheme-4,scheme-5' | split: ',' %}
{% for scheme_id in schemes %}
  {% assign scheme = settings.color_schemes[scheme_id] %}
  {% if scheme != blank %}
.featured-collection.color-{{ scheme_id }} {
  --color-foreground: {{ scheme.settings.text | color_extract: 'red' }}, {{ scheme.settings.text | color_extract: 'green' }}, {{ scheme.settings.text | color_extract: 'blue' }};
  --color-background: {{ scheme.settings.background | color_extract: 'red' }}, {{ scheme.settings.background | color_extract: 'green' }}, {{ scheme.settings.background | color_extract: 'blue' }};
  {% if scheme.settings.background_gradient != blank %}
    --gradient-background: {{ scheme.settings.background_gradient }};
  {% else %}
    --gradient-background: rgba({{ scheme.settings.background | color_extract: 'red' }}, {{ scheme.settings.background | color_extract: 'green' }}, {{ scheme.settings.background | color_extract: 'blue' }}, 1);
  {% endif %}
  --color-button: {{ scheme.settings.button | color_extract: 'red' }}, {{ scheme.settings.button | color_extract: 'green' }}, {{ scheme.settings.button | color_extract: 'blue' }};
  --color-button-text: {{ scheme.settings.button_label | color_extract: 'red' }}, {{ scheme.settings.button_label | color_extract: 'green' }}, {{ scheme.settings.button_label | color_extract: 'blue' }};
  --color-link: {{ scheme.settings.secondary_button_label | color_extract: 'red' }}, {{ scheme.settings.secondary_button_label | color_extract: 'green' }}, {{ scheme.settings.secondary_button_label | color_extract: 'blue' }};

  background-color: rgb(var(--color-background)) !important;
  color: rgb(var(--color-foreground));
}

.featured-collection.color-{{ scheme_id }}.gradient {
  background: var(--gradient-background) !important;
}

/* Featured-collection title styling */
.featured-collection.color-{{ scheme_id }} .collection__title {
  color: var(--fc-text-color, rgb(var(--color-foreground)));
}

.featured-collection.color-{{ scheme_id }} .title {
  color: var(--fc-text-color, rgb(var(--color-foreground)));
}

.featured-collection.color-{{ scheme_id }} .subtitle {
  color: var(--fc-text-color, rgb(var(--color-foreground)));
}

.featured-collection.color-{{ scheme_id }} .collection__description {
  color: var(--fc-text-color, rgb(var(--color-foreground)));
}

/* Featured-collection view all button styling */
.featured-collection.color-{{ scheme_id }} .collection__view-all .button {
  background-color: var(--fc-button-bg, rgb(var(--color-button)));
  color: var(--fc-button-text, rgb(var(--color-button-text)));
  border-color: var(--fc-button-border, rgb(var(--color-button)));
}

.featured-collection.color-{{ scheme_id }} .collection__view-all .button:hover {
  background-color: var(--fc-button-hover-bg, var(--fc-button-bg, rgb(var(--color-button))));
  color: var(--fc-button-hover-text, var(--fc-button-text, rgb(var(--color-button-text))));
  border-color: var(--fc-button-hover-border, var(--fc-button-border, rgb(var(--color-button))));
  opacity: 0.9;
}

.featured-collection.color-{{ scheme_id }} .collection__view-all .button--secondary {
  background-color: transparent;
  color: var(--fc-button-border, rgb(var(--color-button)));
  border-color: var(--fc-button-border, rgb(var(--color-button)));
}

.featured-collection.color-{{ scheme_id }} .collection__view-all .button--secondary:hover {
  background-color: var(--fc-button-hover-bg, var(--fc-button-bg, rgb(var(--color-button))));
  color: var(--fc-button-hover-text, var(--fc-button-text, rgb(var(--color-button-text))));
  border-color: var(--fc-button-hover-border, var(--fc-button-border, rgb(var(--color-button))));
}

.featured-collection.color-{{ scheme_id }} .collection__view-all .link {
  color: var(--fc-link-color, rgb(var(--color-link)));
}

.featured-collection.color-{{ scheme_id }} .collection__view-all .link:hover {
  color: var(--fc-link-hover-color, rgb(var(--color-button)));
}

/* Featured-collection slider button styling */
.featured-collection.color-{{ scheme_id }} .slider-button {
  background-color: var(--fc-button-bg, rgb(var(--color-button)));
  color: var(--fc-button-text, rgb(var(--color-button-text)));
  border-color: var(--fc-button-border, rgb(var(--color-button)));
}

.featured-collection.color-{{ scheme_id }} .slider-button:hover {
  background-color: var(--fc-button-hover-bg, var(--fc-button-bg, rgb(var(--color-button))));
  color: var(--fc-button-hover-text, var(--fc-button-text, rgb(var(--color-button-text))));
  border-color: var(--fc-button-hover-border, var(--fc-button-border, rgb(var(--color-button))));
  opacity: 0.9;
}

/* Featured-collection slider counter styling */
.featured-collection.color-{{ scheme_id }} .slider-counter {
  color: var(--fc-text-color, rgb(var(--color-foreground)));
}
  {% endif %}
{% endfor %}
