    "image_with_text_t6KzFw": {
      "type": "image-with-text",
      "blocks": {
        "text_CcwiLn": {
          "type": "text",
          "settings": {
            "text": "<p>Michael Bodie, founder of <a href=\"https://www.instagram.com/rebellionbarbershop/\"><span style=\"text-decoration:underline\">Rebellion Barbershop</span></a>, first picked up hair cutting as a hobby while studying Philosophy at the <a href=\"https://www.uvic.ca/\"><span style=\"text-decoration:underline\">University of Victoria</span><span style=\"text-decoration:underline\"><em>.</em></span></a> Originally from the Comox Valley, he moved to Victoria in 2010 and began offering haircuts through a Craigslist ad that read: “First haircut free, $10 after that.”. What started as a side hustle between classes quickly turned into something more. As his skills grew, so did his following—eventually leading him behind the chair at local barbershops and into a growing client base. After five years in the industry, Bodie set his sights on something bigger: opening a barbershop of his own.</p><p>In 2018, he launched <a href=\"https://www.rebellionbarber.com/\"><span style=\"text-decoration:underline\">Rebellion Barbershop</span></a> in a restored heritage space at Oak Bay Junction—a location once home to the iconic <em>Figaro Barbershop</em> more than  15 years prior. The space wasn’t even on the market when Bodie found it, but recognizing its potential (and history), he secured the lease before it was ever listed. Rebellion opened with a bold move: an entire month of free haircuts—745 in just four weeks. The strategy paid off. Within a month, Rebellion became<a href=\"https://maps.app.goo.gl/MUKPRdTdXFt4Px7W7\" target=\"_blank\" title=\"https://maps.app.goo.gl/MUKPRdTdXFt4Px7W7\"> the highest-rated barbershop in Victoria</a> on Google Maps. Bodie hired a second barber and began mentoring his first apprentice.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_CcwiLn"
      ],
      "settings": {
        "image": "shopify://shop_images/5N9A2300_copy.jpg",
        "height": "adapt",
        "desktop_image_width": "medium",
