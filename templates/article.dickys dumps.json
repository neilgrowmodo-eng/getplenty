    "image_with_text_t6KzFw": {
      "type": "image-with-text",
      "blocks": {
        "text_CcwiLn": {
          "type": "text",
          "settings": {
            "text": "<p>Rooted in tradition and continually inspired by their appetites, <a href=\"https://dickysdumps.com/\">Dicky's Dumps</a> is a Vancouver-based dumpling business that's co-owned by Pearl Lam and Dickson Li.  Their Chinese dumplings are handmade in small batches and flash frozen to lock in optimal flavour and freshness. </p><p>They have built a business around a comfort food that's so iconic in Chinese culture. Since their inception they have managed to attract a lot of first-time tasters who are now big-time dumpling fans. Together and separately, they’ve been championing community and culture for most of their adult lives — Dickson through cooking and feeding loved ones, and Pearl through creating <a href=\"https://instagram.com/districtlocal\">District Local</a>, a Vancouver passion project. They both participate in a lot of local events and are longtime supporters of the Chinatown community.</p><p></p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_CcwiLn"
      ],
      "settings": {
        "image": "shopify://shop_images/DD_4X5-5257.jpg",
        "height": "adapt",
        "desktop_image_width": "medium",
        "layout": "image_first",
        "desktop_content_position": "middle",
        "desktop_content_alignment": "left",
        "content_layout": "no-overlap",
        "color_scheme": "scheme-1",
