    "image_with_text_CULrcX": {
      "type": "image-with-text",
      "blocks": {
        "text_XnbBY6": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong>What’s one piece in your wardrobe that you can’t live without? </p><p><strong>A</strong>: I’ll always be a sucker for a clean white tennis shoe—not an athletic shoe, a casual one.</p><p>It goes back to high school, I used to go through ten pairs of Tommy Hilfiger a year. But it doesn’t matter the brand—Keds, Vans, Vince, Common Projects—slip-ons or lace-ups.</p><p>For me, a white shoe is the easiest way to achieve a clean, elevated casual look.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_XnbBY6"
      ],
      "settings": {
