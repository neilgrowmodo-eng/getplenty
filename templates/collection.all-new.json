    "blurbs-2": {
      "type": "brand-blurbs-2",
      "blocks": {
        "f492b345-bf00-4bac-9c15-749d3b50c08d": {
          "type": "blurb",
          "settings": {
            "title": "Land of Daughters",
            "text": "<p>Metis + female founded, Land of Daughters has been around since July 2018 with a focus on creating unique scents for our candles, aroma sprays and solid perfumes. They love all things cozy and seasonal, and are homebodies to the core. This is reflected in a lot of the names chosen and also inspires the types of scents designed. With all of their product crafted in Calgary, Alberta, Land of Daughters values knowing where their things came from and knowing where their money goes to. To make a different future for the next generation!</p>"
          }
        },
