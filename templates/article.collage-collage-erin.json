    "image_with_text_t6KzFw": {
      "type": "image-with-text",
      "blocks": {
        "text_CcwiLn": {
          "type": "text",
          "settings": {
            "text": "<p>Step inside <a href=\"https://shop.collagecollage.ca/\"><span style=\"text-decoration:underline\">Collage Collage</span></a> and you’ll find more than just a shop. You'll find an explosion of colour, <a href=\"https://shop.collagecollage.ca/collections/supplies\"><span style=\"text-decoration:underline\">googly eyes</span></a>, <a href=\"https://shop.collagecollage.ca/collections/books\"><span style=\"text-decoration:underline\">picture books</span></a>, and an open invitation to make, try, and <a href=\"https://shop.collagecollage.ca/collections/camps-classes\"><span style=\"text-decoration:underline\">get a little messy</span></a>. Founded by artist and educator Erin Bonifero, the beloved Vancouver studio-slash-storefront has been nurturing creativity in kids (and their grown-ups) since 2009.</p><p>Shaped by years of involvement in community-based art programming and a belief in the power of hands-on making, Erin has built something rare: a space where trying matters more than perfect results, and pipe cleaners and pencil crayons are everyday magic. </p><p>We sat down with Erin to talk about her earliest art memories, her studio uniform, and why a good pen (and a good stain remover) go a long way.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_CcwiLn"
      ],
