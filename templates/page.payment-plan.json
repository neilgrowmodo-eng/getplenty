    "faqs": {
      "type": "main-faqs",
      "blocks": {
        "695a6121-8255-443d-b536-9596f2bdaef0": {
          "type": "faq",
          "settings": {
            "title": "What is Afterpay?",
            "text": "<p>Afterpay is a service that allows you to make purchases now and pay for them in four payments made every two weeks.<\/p>"
          }
        },
        "2b8e8365-2f6f-47ea-a89d-cb0e0550a35f": {
          "type": "faq",
          "settings": {
            "title": "How do I use Afterpay?",
            "text": "<p>Shop with us online and add items to your cart and checkout as normal. At the checkout, choose Afterpay as your payment method. First-time customers will need to register with Afterpay and provide payment details and returning customers log in to make their purchase.<\/p>"
          }
        },
        "374130de-cdf2-4df2-8526-6471c5aa43a1": {
          "type": "faq",
          "settings": {
            "title": "Can I use Afterpay if I'm an international customer?",
            "text": "<p>Afterpay can only be applied to purchases made online at getplenty.com for Canadian customers.<\/p>"
          }
        },
        "dd9f7a21-619e-428c-9967-dcca309a0e78": {
          "type": "faq",
          "settings": {
            "title": "How does the payment schedule work?",
            "text": "<p>All customers are required to make their first payment at the time of purchase, with the remaining three payments deducted every two weeks from your chosen payment method. For more questions about payment visit <a href=\"https:\/\/help.afterpay.com\/hc\/en-us\/sections\/203376123-Payments\"><span style=\"text-decoration:underline\">Afterpay Payments FAQ here.<\/span><\/a><\/p>"
          }
        },
        "faq_pkcXMk": {
          "type": "faq",
          "settings": {
            "title": "When will my items be delivered if I use Afterpay?",
            "text": "<p>Afterpay orders are delivered based on our standard shipping time frame after you complete your order online. Visit our delivery and returns page for more information by clicking <a href=\"https:\/\/www.getplenty.com\/pages\/delivery-returns\"><span style=\"text-decoration:underline\">here<\/span><\/a>.<\/p>"
          }
        },
        "faq_V7JkxX": {
          "type": "faq",
          "settings": {
            "title": "How do I return or exchange an item purchased using Afterpay?",
            "text": "<p>If you have changed your mind, you can return your Afterpay purchase in-store or by mail for a refund. Please check that your return or exchange meets our Return Policy <a href=\"https:\/\/www.getplenty.com\/pages\/delivery-returns\"><span style=\"text-decoration:underline\">here<\/span><\/a>. Please do not return your purchase to Afterpay. If you believe there is fault or concern with your Afterpay purchase payment, please contact Afterpay customer support at <a href=\"mailto:info@afterpay.com\"><span style=\"text-decoration:underline\">info@afterpay.com<\/span><\/a><\/p>"
          }
        },
        "1d018b10-2de7-4b73-9f47-4a7292bec079": {
          "type": "faq",
          "settings": {
            "title": "Where can I find more about Afterpay?",
            "text": "<p>If you would like to know more about Afterpay, visit <a href=\"http:\/\/www.afterpay.com\/\"><span style=\"text-decoration:underline\">www.afterpay.com <\/span><\/a>for a comprehensive list of <a href=\"https:\/\/help.afterpay.com\/hc\/en-us\/\"><span style=\"text-decoration:underline\">FAQs<\/span><\/a>, terms, <a href=\"https:\/\/www.afterpay.com\/en-CA\/instalment-agreement\"><span style=\"text-decoration:underline\">instalment agreement <\/span><\/a>along with Afterpay’s Privacy Policy which can be found a t<a href=\"https:\/\/www.afterpay.com\/en-CA\/privacy-policy\"><span style=\"text-decoration:underline\">www.afterpay.com\/en-CA\/privacy-policy<\/span><\/a>. If you have any questions about your Afterpay account, please contact Afterpay directly via a web form found <a href=\"https:\/\/help.afterpay.com\/hc\/en-us\/requests\/new\"><span style=\"text-decoration:underline\">here<\/span><\/a>.<\/p>"
          }
        }
      },
