    "image_with_text_NjQ3EM": {
      "type": "image-with-text",
      "blocks": {
        "text_ENV8fL": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q:</strong> Your pieces have a candy-like, joyful quality. Are there any edible inspirations that influence your palette or shapes?</p><p><strong>A: </strong>I love candy! Everything I make is very candy-inspired. Some of my favourites are Nerds and M&M’s. Most of the pieces I create are based on different candies.  </p>",
            "text_style": "body"
          }
        }
      },
