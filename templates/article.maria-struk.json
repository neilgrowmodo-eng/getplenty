    "image_with_text_c4jGUN": {
      "type": "image-with-text",
      "blocks": {
        "text_WTVxJJ": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong>Your pieces are as functional as they are beautiful. What do you hope people feel when they live with your objects day to day?</p><p>When people interact with my objects, I really hope they feel joy and happiness, and it reminds them of their childhood. I hope they feel nostalgic and happy. </p>",
            "text_style": "body"
          }
        }
      },
