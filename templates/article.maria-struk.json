    "image_with_text_FAfVaW": {
      "type": "image-with-text",
      "blocks": {
        "text_tfc8jA": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q:</strong> How much does spontaneity play a role in your process, versus careful planning?</p><p><strong>A:</strong> When I’m making production items, everything is planned out and not spontaneous. If I’m working on something new, I kind of have a general idea of how I would like it to look. Learning something new and working with something new can be challenging at times, so I kind of just go with the flow. </p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_tfc8jA"
      ],
