    "image_with_text_KhDeH8": {
      "type": "image-with-text",
      "blocks": {
        "text_UjdTaz": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong>How would you describe your style?</p><p><strong>A: </strong>I like stiff clothing—rigid materials that break in and hold their structure. Clothes you can beat up, that earn character through use.</p><p><strong>Q: </strong>Any upcoming personal projects you’d like to share with us, or a sneak peek?</p><p><strong>A: </strong>I’m restoring my father’s house—the one I grew up in. It’s a former church, built in 1902. There’s no running water, just wood stove heat and original wood construction. It’s a real '70s back-to-the-land kind of project that my parents started. I plan to repair what needs fixing but otherwise leave it as it was. One day, I’ll move back home.</p>",
            "text_style": "body"
          }
        }
      },
