    "image_with_text_9WEiBt": {
      "type": "image-with-text",
      "blocks": {
        "text_Qjbd39": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q:</strong> What’s the most rewarding part of your job?</p><p><strong>A:</strong> That it’s been around for almost 16 years, has weathered many storms, and continues to succeed — and to be acknowledged by both my customers and industry peers as one of the best in the coffee business.</p><p><strong>Q: </strong>If you could give your younger self one piece of advice, what would it be?</p><p><strong>A: </strong>Take better care of yourself, and eat well.</p><p><strong>Q: </strong>What’s your favourite childhood snack?</p><p><strong>A: </strong>Toasted rye bread with lots of butter and honey.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_Qjbd39"
      ],
      "settings": {
        "image": "shopify://shop_images/sam_james_30.jpg",
