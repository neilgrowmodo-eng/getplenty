    "image_with_text_t6KzFw": {
      "type": "image-with-text",
      "blocks": {
        "text_CcwiLn": {
          "type": "text",
          "settings": {
            "text": "<p><a href=\"https://www.instagram.com/justjorosenthal/?hl=en\" target=\"_blank\" title=\"https://www.instagram.com/justjorosenthal/?hl=en\">Jo Rosenthal </a>is a New York-based writer, artist, and woman about town specializing in fashion, art, and culture. With a background in Fine Arts and Writing from <em>The New School for Design</em>, Jo has been writing for as long as she can remember. What began as a hobby turned into a passion, leading her to contribute to multiple websites as a fashion and culture writer, as well as publish zines and books that can be found at zine fairs around the world, at <a href=\"https://www.printedmatter.org/\" target=\"_blank\" title=\"https://www.printedmatter.org/\"><em>Printed Matter</em></a>, and in the <em>MoMa library</em>.</p><p></p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_CcwiLn"
      ],
      "settings": {
        "image": "shopify://shop_images/IMG_5289.jpg",
        "height": "adapt",
        "desktop_image_width": "small",
        "layout": "image_first",
        "desktop_content_position": "middle",
        "desktop_content_alignment": "left",
        "content_layout": "no-overlap",
        "color_scheme": "background-1",
