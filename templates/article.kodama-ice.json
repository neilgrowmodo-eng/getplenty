    "image_with_text_nk8Wzf": {
      "type": "image-with-text",
      "blocks": {
        "text_97eaFM": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q:</strong> Describe your ideal dinner party. What’s being served, what’s playing in the background, and what’s in the glass? </p><p><strong>A:</strong> Somewhere outside at sunset cooking over a wood fire with a whole variety of meat with summers bountiful vegetables and salad. 4 piece bluegrass band in the back. Probably sipping on whisky highballs.</p>",
            "text_style": "body"
          }
        }
      },
