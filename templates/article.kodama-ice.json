        "text_4RPdND": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong>How would you describe your personal style? </p><p><strong>A</strong>: Understated. I'm very casual, but at the same time, I like to accentuate with just one statement piece.</p>",
            "text_style": "body"
          }
        }
      },
