    "image_with_text_c4jGUN": {
      "type": "image-with-text",
      "blocks": {
        "text_WTVxJJ": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong>What does a day in your life look like when you're not behind the camera?</p><p><strong>A: </strong>It’s all about spending as much quality time as I can with my toddler right now. I’ve come to accept that this season of life doesn’t leave much room for personal work, and that’s okay.</p><p></p>",
            "text_style": "body"
          }
        }
      },
