    "image_with_text_9WEiBt": {
      "type": "image-with-text",
      "blocks": {
        "text_Qjbd39": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q:</strong> Favourite childhood snack?</p><p><strong>A:</strong> Maltesers.</p><p><strong>Q:</strong> How would you describe your personal style?</p><p><strong>A: </strong>Boyish. I love military-inspired fashion—bomber jackets, cargo pants, camouflage, army tones.</p><p><strong>Q:</strong>Any upcoming personal projects you’d like to share?</p><p><strong>A: </strong>I just finished a 5x10 foot painting that’s going to be installed at a friend’s new food hall opening in Richmond. Keep an eye out!</p>",
            "text_style": "body"
          }
        }
      },
