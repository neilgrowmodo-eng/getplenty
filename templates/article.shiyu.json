    "image_with_text_c4jGUN": {
      "type": "image-with-text",
      "blocks": {
        "text_WTVxJJ": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q:</strong> What’s the most rewarding part of your job?</p><p><strong>A:</strong>The people. I do a lot of large-scale work, which means seeing clients regularly over long periods of time. Sometimes, I see them more often than I see my own family. The friendships I’ve built—and the things I’ve learned from those conversations—mean the world to me.</p><p><strong>Q: </strong>If you could give your younger self one piece of advice, what would it be?</p><p><strong>A:</strong> Being present and practicing gratitude solves most things.</p>",
            "text_style": "body"
          }
        }
      },
