        "text_CLbqn8": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong></p><p>What are three words your friends or family would use to describe you?</p><p><strong>A: </strong></p><p>Crazy, loud, and funny.</p><p><strong>Q: </strong></p><p>Tell us the story behind Studio Fundamentals.</p><p><strong>A:</strong></p><p> Studio Fundamentals started in 2017 with the intent of documenting my design work. It began as graphic design, then evolved from 2D design to what it is now—pottery.</p>",
            "text_style": "body"
          }
        }
