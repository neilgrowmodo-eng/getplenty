    "image_with_text_wKVLmh": {
      "type": "image-with-text",
      "blocks": {
        "text_CLbqn8": {
          "type": "text",
          "settings": {
            "text": "<p>Today, Rebellion has two locations, a team of eight barbers, and features a house-made <a href=\"https://www.rebellionbarber.com/goods\"><span style=\"text-decoration:underline\">product line</span></a> sold both in-shop and wholesale. Bodie now spends his time training new barbers, managing product distribution, and staying connected to the clients who’ve been with him from the start. With over a decade of experience, Rebellion continues to be built on craftsmanship, community, and a commitment to helping others grow. We caught up with Michael to hear how he turned a personal hobby into one of Victoria’s most respected barbershops. Read the full interview below.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_CLbqn8"
      ],
      "disabled": true,
      "settings": {
        "height": "adapt",
        "desktop_image_width": "medium",
