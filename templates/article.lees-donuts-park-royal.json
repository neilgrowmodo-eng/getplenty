    "image_with_text_t6KzFw": {
      "type": "image-with-text",
      "blocks": {
        "text_CcwiLn": {
          "type": "text",
          "settings": {
            "text": "<p>Johnny Glaze and the <a href=\"https://www.instagram.com/leesdonuts.ca/\" target=\"_blank\" title=\"Lee's Donuts on Instagram\">Lee’s Donuts</a> team are back. This time at <a href=\"https://www.getplenty.com/pages/store-locator\" title=\"Plenty Store Locator\">Plenty Park Royal</a>. From August 2–4, join us for a three-day pop-up featuring iconic Lee’s Donuts—freshly made, with a surprise limited-edition flavour in the mix (while supplies last). </p><p>Come by to shop, snack, and meet the legend himself, Johnny Glaze, in-store on Saturday, August 3 from 2–4PM. And just for the occasion, we’re dropping a <em>surprise in-store sale</em>—only during the pop-up, only at Plenty Park Royal. </p><p>It’s the return of the perfect pairing: sweet treats and sweet fits.</p><p></p><p><strong>Where:</strong> Plenty Park Royal — 2002 Park Royal S, West Vancouver, BC V7T 2W4</p><p><strong>When:</strong></p><p>Saturday, August 2: 10AM–7PM</p><p>Sunday, August 3: 11AM–6PM</p><p>Monday, August 4: 11AM–6PM</p><p><br/></p><p>Donuts will be available to purchase by singles, boxes of 6, and boxes of 12.</p>",
            "text_style": "body"
          }
        }
      },
