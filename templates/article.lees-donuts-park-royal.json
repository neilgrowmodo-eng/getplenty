    "image_with_text_c4jGUN": {
      "type": "image-with-text",
      "blocks": {
        "text_WTVxJJ": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong>How would you describe your style?</p><p><strong>Nina: </strong>Anything comfortable. Earth tones. I love asymmetry, pattern mixing and layering. Summer is hard for me because I don’t know how to layer for summer. A nice silhouette with layers and colour. </p><p><strong>Dejan:</strong> Fun workwear, DIY, colour. A little bit of hype beast and thrift. </p><p><strong>Q: </strong>Advice for any new parents?</p><p><strong>Nina & Dejan: </strong>Work on yourself. Be the best version of yourself that you can be. Be patient and grow with your children.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_WTVxJJ"
      ],
      "disabled": true,
      "settings": {
        "image": "shopify://shop_images/IMG_9030-Enhanced-NR.jpg",
