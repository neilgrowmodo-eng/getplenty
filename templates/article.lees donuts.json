    },
    "image_with_text_NjQ3EM": {
      "type": "image-with-text",
      "blocks": {
        "text_ENV8fL": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong>How would you describe your personal style? Classic glaze, jelly-core streetwear, or powdered chic? </p><p><strong>A: </strong>My style is definitely that classic glazed-and-confused look. I may not say much, but my style and colours speak volumes. And I only know one volume: loud. </p><p><strong>Q:</strong> What’s your go-to wardrobe essential that pairs best with... well, you?</p><p><strong>A:</strong> Every now-and-then I’ll throw on some donut bling like sprinkles or sugar crystals for that special occasion. </p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_ENV8fL"
      ],
      "settings": {
        "image": "shopify://shop_images/IMG_6409-Enhanced-NR.jpg",
