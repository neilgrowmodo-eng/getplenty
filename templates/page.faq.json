        "2b8e8365-2f6f-47ea-a89d-cb0e0550a35f": {
          "type": "faq",
          "settings": {
            "title": "Do you sell gift cards?",
            "text": "<p>Yes, please click <a href=\"https:\/\/www.getplenty.com\/products\/gift-card\" title=\"Gift Card\">here <\/a>to purchase one online.<\/p>"
