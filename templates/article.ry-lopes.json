    "image_with_text_jzjctF": {
      "type": "image-with-text",
      "blocks": {
        "text_raakbm": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong>What’s the most rewarding part of your job?</p><p><strong>A: </strong>The exchange and sentiment that we have to be driven by our taste, values and overall truth. It’s really rewarding to see how we share this moment and yet uncover so many elements that feed us, and drive us. I’ve really been focusing on that lately and how I can be rewarded with what I chose to stand by.</p>",
            "text_style": "body"
          }
        }
      },
