      }
    },
    "image_with_text_FAfVaW": {
      "type": "image-with-text",
      "blocks": {
        "text_tfc8jA": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q: </strong>What’s your favourite childhood snack?</p><p><strong>A: </strong>Ohhhh. Good question! I really liked Mint Chip Ice Cream & also Sunflower Seeds (so random, but yes). </p><p><strong>Q: </strong>If you could give your younger self one piece of advice, what would it be?</p><p><strong>A: </strong>The same advice I would give myself now. To not overthink it. To just be. We can always pull out what isn’t working later, or what doesn’t feel true.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_tfc8jA"
      ],
      "settings": {
        "image": "shopify://shop_images/IMG_2688.heic",
