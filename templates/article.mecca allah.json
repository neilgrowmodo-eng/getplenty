    "image_with_text_t6KzFw": {
      "type": "image-with-text",
      "blocks": {
        "text_CcwiLn": {
          "type": "text",
          "settings": {
            "text": "<p><a href=\"https://www.instagram.com/mecca_allah/\"><span style=\"text-decoration:underline\">Mecca Allah </span></a>is an Afro-Latina model and multidisciplinary artist based in Brooklyn, NY, with a strong focus on movement. She’s also a dedicated wellness practitioner with a deep love for herbal medicine—you can find her handcrafted, small-batch natural products at <a href=\"https://www.instagram.com/meccalaluna/\"><span style=\"text-decoration:underline\">@meccalaluna</span></a>.</p><p>A passionate world traveler, Mecca thrives on exploring new places and cultures. She’s also a newly certified yoga instructor. After sustaining multiple dance-related injuries, she turned to yoga for rehabilitation and quickly fell in love with its healing power and holistic benefits.</p><p>Today, her greatest passion lies in sharing love through art, movement, and wellness. </p><p>We caught up with Mecca to learn more about her creative journey as a model, multidisciplinary artist, and founder of her own wellness brand <em>Mecca La Luna</em>.</p><p>Read on to learn more.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "text_CcwiLn"
      ],
      "settings": {
        "image": "shopify://shop_images/Photo_Apr_22_2025_14_45_09.jpg",
        "height": "adapt",
        "desktop_image_width": "small",
        "layout": "image_first",
