    "image_with_text_NcaaC4": {
      "type": "image-with-text",
      "blocks": {
        "text_pbeYkT": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Q:</strong> If you could give your younger self one piece of advice, what would it be?</p><p><strong>A: </strong>Live with no fear and don’t stress about what hasn’t happened yet, live in the moment and really just soak up all the good and learn from the bad.</p><p><strong>Q:</strong> Any upcoming personal projects you’d like to share with us or a sneak peak?</p><p><strong>A: </strong>I have been working on a collaborative film that I’m really excited about and I can’t wait for it to be finished and for the world to see.</p>",
            "text_style": "body"
          }
        }
      },
