{% doc %}
  @prompt
    A multi-column section with one image per column. These columns should be responsive, and allow for a desktop media file and a mobile media file. Each media file should have the ability to link to another page. The padding of the section (top, bottom, right, left) should be adjustable, as well as the spacing between each column. Maximum four columns in this section. Allow this section to be reused., Allow me to turn off extra columns as necessary.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multi-column-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }

  .ai-multi-column-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.column_spacing }}px;
    max-width: 100%;
  }

  .ai-multi-column-item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-multi-column-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-decoration: none;
  }

  .ai-multi-column-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-multi-column-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-multi-column-image-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-multi-column-image-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-multi-column-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-multi-column-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-multi-column-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-multi-column-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-multi-column-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-multi-column-image-mobile-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<div class="ai-multi-column-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-multi-column-container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign enabled_key = 'enable_column_' | append: i
        assign image_desktop_key = 'image_desktop_' | append: i
        assign image_mobile_key = 'image_mobile_' | append: i
        assign link_key = 'link_' | append: i

        assign enabled = block.settings[enabled_key]
        assign image_desktop = block.settings[image_desktop_key]
        assign image_mobile = block.settings[image_mobile_key]
        assign link = block.settings[link_key]
      %}

      {% if enabled %}
        <div class="ai-multi-column-item-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-multi-column-link-{{ ai_gen_id }}">
          {% endif %}

          <div class="ai-multi-column-image-wrapper-{{ ai_gen_id }}">
            {% if image_desktop != blank or image_mobile != blank %}
              {% if image_desktop != blank %}
                <img
                  src="{{ image_desktop | image_url: width: 1000 }}"
                  alt="{{ image_desktop.alt | escape }}"
                  loading="lazy"
                  width="{{ image_desktop.width }}"
                  height="{{ image_desktop.height }}"
                  class="ai-multi-column-image-{{ ai_gen_id }} ai-multi-column-image-desktop-{{ ai_gen_id }}"
                >
              {% endif %}

              {% if image_mobile != blank %}
                <img
                  src="{{ image_mobile | image_url: width: 800 }}"
                  alt="{{ image_mobile.alt | escape }}"
                  loading="lazy"
                  width="{{ image_mobile.width }}"
                  height="{{ image_mobile.height }}"
                  class="ai-multi-column-image-{{ ai_gen_id }} ai-multi-column-image-mobile-{{ ai_gen_id }}"
                >
              {% elsif image_desktop != blank %}
                <img
                  src="{{ image_desktop | image_url: width: 800 }}"
                  alt="{{ image_desktop.alt | escape }}"
                  loading="lazy"
                  width="{{ image_desktop.width }}"
                  height="{{ image_desktop.height }}"
                  class="ai-multi-column-image-{{ ai_gen_id }} ai-multi-column-image-mobile-{{ ai_gen_id }}"
                >
              {% endif %}
            {% else %}
              <div class="ai-multi-column-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-multi-column-empty-state-{{ ai_gen_id }}">
                  Next, add an image for column {{ i }}
                </div>
              </div>
            {% endif %}
          </div>

          {% if link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

