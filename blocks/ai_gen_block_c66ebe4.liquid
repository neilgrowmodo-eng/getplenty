{% doc %}
  @prompt
    A multi-column section with one image per column. These columns should be responsive, and allow for a desktop media file and a mobile media file. Each media file should have the ability to link to another page. The padding of the section (top, bottom, right, left) should be adjustable, as well as the spacing between each column. Maximum four columns in this section. Allow this section to be reused. , each column should have a single image, with the ability to set a desktop image and mobile image , two images are still showing per column. only one image should be displayed, with a specific setting for desktop or mobile, allow all content to be centered in the section, remove spacing, padding and margins from in between each column. spacing should only be able to be adjusted on the left and right , all content should be centred in the section. it is not centred, each image should have both a desktop file and a mobile file to be asset
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-columns-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-media-columns-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }

  .ai-media-columns-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: 0;
    max-width: 100%;
  }

  .ai-media-column-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-media-column-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-decoration: none;
  }

  .ai-media-column-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-media-column-image-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-media-column-image-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-media-column-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-media-column-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-media-column-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-media-columns-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-media-column-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-media-column-image-mobile-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<div class="ai-media-columns-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-media-columns-wrapper-{{ ai_gen_id }}">
    <div class="ai-media-columns-container-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign column_enabled_key = 'column_' | append: i | append: '_enabled'
          assign desktop_image_key = 'column_' | append: i | append: '_desktop_image'
          assign mobile_image_key = 'column_' | append: i | append: '_mobile_image'
          assign link_key = 'column_' | append: i | append: '_link'

          assign column_enabled = block.settings[column_enabled_key]
          assign desktop_image = block.settings[desktop_image_key]
          assign mobile_image = block.settings[mobile_image_key]
          assign link = block.settings[link_key]
        %}

        {% if column_enabled %}
          <div class="ai-media-column-{{ ai_gen_id }}">
            {% if link != blank %}
              <a href="{{ link }}" class="ai-media-column-link-{{ ai_gen_id }}">
                {% if desktop_image != blank %}
                  <img
                    src="{{ desktop_image | image_url: width: 1200 }}"
                    alt="{{ desktop_image.alt | escape }}"
                    loading="lazy"
                    width="{{ desktop_image.width }}"
                    height="{{ desktop_image.height }}"
                    class="ai-media-column-image-{{ ai_gen_id }} ai-media-column-image-desktop-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-media-column-placeholder-{{ ai_gen_id }} ai-media-column-image-desktop-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                    <div class="ai-media-column-empty-state-{{ ai_gen_id }}">
                      Add desktop image
                    </div>
                  </div>
                {% endif %}

                {% if mobile_image != blank %}
                  <img
                    src="{{ mobile_image | image_url: width: 800 }}"
                    alt="{{ mobile_image.alt | escape }}"
                    loading="lazy"
                    width="{{ mobile_image.width }}"
                    height="{{ mobile_image.height }}"
                    class="ai-media-column-image-{{ ai_gen_id }} ai-media-column-image-mobile-{{ ai_gen_id }}"
                  >
                {% elsif desktop_image != blank %}
                  <img
                    src="{{ desktop_image | image_url: width: 800 }}"
                    alt="{{ desktop_image.alt | escape }}"
                    loading="lazy"
                    width="{{ desktop_image.width }}"
                    height="{{ desktop_image.height }}"
                    class="ai-media-column-image-{{ ai_gen_id }} ai-media-column-image-mobile-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-media-column-placeholder-{{ ai_gen_id }} ai-media-column-image-mobile-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                    <div class="ai-media-column-empty-state-{{ ai_gen_id }}">
                      Add mobile image
                    </div>
                  </div>
                {% endif %}
              </a>
            {% else %}
              {% if desktop_image != blank %}
                <img
                  src="{{ desktop_image | image_url: width: 1200 }}"
                  alt="{{ desktop_image.alt | escape }}"
                  loading="lazy"
                  width="{{ desktop_image.width }}"
                  height="{{ desktop_image.height }}"
                  class="ai-media-column-image-{{ ai_gen_id }} ai-media-column-image-desktop-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-media-column-placeholder-{{ ai_gen_id }} ai-media-column-image-desktop-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                  <div class="ai-media-column-empty-state-{{ ai_gen_id }}">
                    Add desktop image
                  </div>
                </div>
              {% endif %}

              {% if mobile_image != blank %}
                <img
                  src="{{ mobile_image | image_url: width: 800 }}"
                  alt="{{ mobile_image.alt | escape }}"
                  loading="lazy"
                  width="{{ mobile_image.width }}"
                  height="{{ mobile_image.height }}"
                  class="ai-media-column-image-{{ ai_gen_id }} ai-media-column-image-mobile-{{ ai_gen_id }}"
                >
              {% elsif desktop_image != blank %}
                <img
                  src="{{ desktop_image | image_url: width: 800 }}"
                  alt="{{ desktop_image.alt | escape }}"
                  loading="lazy"
                  width="{{ desktop_image.width }}"
                  height="{{ desktop_image.height }}"
                  class="ai-media-column-image-{{ ai_gen_id }} ai-media-column-image-mobile-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-media-column-placeholder-{{ ai_gen_id }} ai-media-column-image-mobile-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                  <div class="ai-media-column-empty-state-{{ ai_gen_id }}">
                    Add mobile image
                  </div>
                </div>
              {% endif %}
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

